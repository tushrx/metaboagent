# MetaboAgent — environment variables
# Copy this file to `.env` and fill in values. `.env` is gitignored.
# Do NOT commit real secrets.

# --- LLM (required) ---
# Shared secret used by vLLM's --api-key flag. Never leave blank.
PRIMARY_LLM_API_KEY=

# Optional overrides (defaults in config.py apply when unset)
# PRIMARY_LLM_BASE_URL=http://localhost:8000/v1
# PRIMARY_LLM_MODEL_NAME=google/gemma-4-31B-it

# --- Utility model (optional; unset = not configured) ---
# UTILITY_LLM_BASE_URL=http://localhost:8001/v1
# UTILITY_LLM_MODEL_NAME=google/gemma-4-e4b-it
# UTILITY_LLM_API_KEY=

# --- Storage paths (optional) ---
# METABOAGENT_DATA_ROOT=/mnt/storage_sdd/metaboagent/data
# METABOAGENT_LOG_DIR=/mnt/storage_sdd/metaboagent/logs
# METABOAGENT_MODEL_CACHE_DIR=/mnt/storage_sdd/hf-cache

# --- UI ---
# UI_HOST=0.0.0.0
# UI_PORT=7860

# --- Demo mode (Phase 7) ---
# DEMO_MODE=0
